# ── PostgreSQL ───────────────────────────────
POSTGRES_PASSWORD=change_me
POSTGRES_USER=postgres
POSTGRES_DB=lmutry

# asyncpg DSN used by the backend
DATABASE_URL=postgresql+asyncpg://postgres:change_me@localhost:5432/lmutry

# ── CORS ─────────────────────────────────────
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
